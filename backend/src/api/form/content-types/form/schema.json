{
  "kind": "collectionType",
  "collectionName": "forms",
  "info": {
    "singularName": "form",
    "pluralName": "forms",
    "displayName": "Form"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "FormFields": {
      "type": "dynamiczone",
      "components": [
        "form-fields.input-field",
        "form-fields.input-area",
        "form-fields.select",
        "form-fields.radio-field",
        "form-fields.check-box",
        "form-fields.boolean-fields"
      ]
    },
    "submitButtonText": {
      "type": "string"
    },
    "variant": {
      "type": "enumeration",
      "enum": [
        "Default",
        "Card",
        "Dark",
        "Glass",
        "Luxury"
      ]
    },
    "cardDescription": {
      "type": "string"
    },
    "cardButtonText": {
      "type": "string"
    }
  }
}
